generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Worker {
  id               String   @id @default(cuid())
  fullName         String
  phone            String?
  age              Int?
  photoUrl         String?
  cloudinaryId     String?
  bio              String?
  city             String   @default("Djibouti-Ville")
  neighborhood     String?
  available        Boolean  @default(true)
  verified         Boolean  @default(false)
  featured         Boolean  @default(false)
  experience       Int?
  languages        String[] @default(["Français", "Somali"])
  tasks            String[] @default([])
  priceFdj         Int?
  workType         String[] @default([])
  schedule         String[] @default([])
  employerProvides String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  reviews          Review[]
}

model Review {
  id         String   @id @default(cuid())
  workerId   String
  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  clientName String
  rating     Int
  comment    String?
  approved   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model ServiceCategory {
  id           String @id @default(cuid())
  slug         String @unique
  label        String
  icon         String
  defaultPrice Int
}
