generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Worker {
  id               String              @id @default(cuid())
  fullName         String
  phone            String?
  age              Int?
  photoUrl         String?
  cloudinaryId     String?
  bio              String?
  city             String              @default("Djibouti-Ville")
  neighborhood     String?
  available        Boolean             @default(true)
  availableFrom    DateTime?
  verified         Boolean             @default(false)
  verifiedSkills   String[]            @default([])
  featured         Boolean             @default(false)
  status           String              @default("ACTIVE")
  selfRegistered   Boolean             @default(false)
  experience       Int?
  languageLevels   Json                @default("[]")
  tasks            String[]            @default([])
  priceFdj         Int?
  workType         String[]            @default([])
  schedule         String[]            @default([])
  employerProvides String[]            @default([])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  reviews          Review[]
  history          WorkerHistory[]
  alerts           AvailabilityAlert[]
}

model Employer {
  id           String              @id @default(cuid())
  email        String              @unique
  passwordHash String
  name         String
  phone        String?
  createdAt    DateTime            @default(now())
  history      WorkerHistory[]
  alerts       AvailabilityAlert[]
  reviews      Review[]
}

model WorkerHistory {
  id         String    @id @default(cuid())
  employerId String
  workerId   String
  status     String    @default("ACTIVE")
  startDate  DateTime  @default(now())
  endDate    DateTime?
  employer   Employer  @relation(fields: [employerId], references: [id], onDelete: Cascade)
  worker     Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([employerId, workerId])
  @@index([workerId])
}

model AvailabilityAlert {
  id         String   @id @default(cuid())
  employerId String
  workerId   String
  createdAt  DateTime @default(now())
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([employerId, workerId])
  @@index([workerId])
}

model Review {
  id         String    @id @default(cuid())
  workerId   String
  worker     Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  employerId String?
  employer   Employer? @relation(fields: [employerId], references: [id], onDelete: SetNull)
  clientName String
  anonymous  Boolean   @default(false)
  rating     Int
  comment    String?
  approved   Boolean   @default(true)
  createdAt  DateTime  @default(now())
}

model ServiceCategory {
  id           String @id @default(cuid())
  slug         String @unique
  label        String
  icon         String
  defaultPrice Int
}
